# Application
APP_NAME=itau-ms
APP_ENV=dev
LOG_LEVEL=INFO
# Formato de log: json (padrão, estruturado) ou console (dev)
LOG_FORMAT=json

# Observabilidade — tracing OpenTelemetry (desligado por padrão)
OTEL_ENABLED=false
# Endpoint OTLP/HTTP (ex.: http://localhost:4318 para o Jaeger do perfil observability).
# Vazio + OTEL_ENABLED=true => exporter de console.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=itau-ms
# Fail-fast: força validação das keys obrigatórias mesmo em dev
REQUIRE_LLM_KEYS=false
# Expõe /docs e /redoc (sempre desabilitado quando APP_ENV=prod)
ENABLE_DOCS=true
# Allowlist de modelos que o cliente pode requisitar (JSON). Vazio = cliente não pode sobrescrever.
ALLOWED_MODELS=["meta-llama/llama-3.3-70b-instruct:free"]

# Segurança
# Hash SHA-256 (hex) da API key aceita no header X-API-Key. NUNCA commitar a key.
# Gere com: python -c "import hashlib,sys;print(hashlib.sha256(sys.argv[1].encode()).hexdigest())" <sua-key>
# Vazio = auth desabilitada (permitido só em dev/test; obrigatório fora deles).
API_KEY_HASH=
# Rate limit por (API key, IP): janela deslizante em memória
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
# Limite global do body da requisição (bytes) -> 413
MAX_BODY_BYTES=65536
# Origins permitidas no CORS (JSON). Vazio = cross-origin bloqueado (padrão seguro).
CORS_ALLOWED_ORIGINS=[]

# Docker Compose (usadas apenas pelo docker-compose.yml; têm defaults sensatos)
# POSTGRES_PASSWORD=postgres
# POSTGRES_PORT=5432
# APP_PORT=8000

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/itau_ms
# Backend do repositório: postgres (padrão) ou memory (dev/testes sem banco)
REPOSITORY_BACKEND=postgres
# Pool assíncrono do SQLAlchemy
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# LLM providers (never commit real keys)
OPENROUTER_API_KEY=changeme
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
GEMINI_API_KEY=changeme
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# Seleção automática de modelos (ligada por padrão): o serviço consulta os
# catálogos dos providers (GET /models) e escolhe o melhor modelo por modo:
#   - elegibilidade: suporta chat/generateContent, limite de saída >= teto do
#     modo (LLM_*_MAX_TOKENS) e contexto >= 8k (margem p/ prompts de 4000 chars);
#   - preço: free primeiro (OpenRouter pricing=0; Gemini família flash), depois
#     menor custo por token; previews/experimentais são evitados;
#   - direct  -> o MENOR modelo elegível (ex.: 3b, flash-lite) = mais barato/rápido;
#   - detailed -> o MAIS capaz do tier free (ex.: 70b, flash), versão mais recente.
# A seleção é revista a cada LLM_MODEL_REFRESH_SECONDS (lazy, no request após
# expirar). Falha no catálogo nunca derruba o request: mantém a última seleção
# ou usa OPENROUTER_MODEL/GEMINI_MODEL como fallback. Overrides manuais
# OPENROUTER_MODEL_DIRECT/GEMINI_MODEL_DIRECT continuam vencendo se definidos.
LLM_AUTO_MODEL=true
LLM_MODEL_REFRESH_SECONDS=3600

# Grounding com busca web (Gemini google_search / OpenRouter web plugin).
# Ligue para respostas com dados atuais (ex.: cotacao do dolar do dia).
# Atencao: pode ter custos/limites proprios nos providers.
LLM_WEB_SEARCH=false

# Modo de resposta e roteamento por custo/eficiencia:
# - response_mode "direct" (padrao do endpoint): resposta objetiva, teto baixo
#   de tokens de saida e, se configurado abaixo, um modelo mais leve/barato.
# - response_mode "detailed": contexto adicional, teto maior, modelo principal.
# Sugestoes de modelos leves: OpenRouter "meta-llama/llama-3.2-3b-instruct:free";
# Gemini "gemini-2.0-flash-lite" (confirme no catalogo da sua key).
OPENROUTER_MODEL_DIRECT=
GEMINI_MODEL_DIRECT=
LLM_DIRECT_MAX_TOKENS=256
LLM_DETAILED_MAX_TOKENS=1024

# Cache de respostas com TTL: prompts identicos (mesmo texto+modo) na janela
# reutilizam a resposta ja gerada — latencia de ms e zero tokens. 0 desliga.
LLM_CACHE_TTL_SECONDS=60

# Warm-up no startup: chamada minima em background que exercita a selecao de
# modelos/auto-cura antes do primeiro usuario (evita fallback na 1a carga).
LLM_WARMUP=true

# System prompt fixo enviado ao LLM (mitigação de prompt injection).
# Tem default seguro no código; descomente apenas para customizar.
# LLM_SYSTEM_PROMPT=You are a helpful assistant...

# HTTP client / resiliência
LLM_TIMEOUT_SECONDS=30
# Retries só para erros transitórios (timeout, 429, 5xx); backoff exponencial + jitter
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_INITIAL_SECONDS=0.5
LLM_RETRY_BACKOFF_MAX_SECONDS=4
# Circuit breaker por provider
LLM_BREAKER_FAILURE_THRESHOLD=5
LLM_BREAKER_COOLDOWN_SECONDS=30
# Timeout curto do check llm_egress no /ready
READY_CHECK_TIMEOUT_SECONDS=2
